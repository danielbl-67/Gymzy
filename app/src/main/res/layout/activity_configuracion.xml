<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivPerfilUsuario"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:layout_marginBottom="25dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/CircleImage"
            android:src="@android:drawable/ic_menu_camera"
            app:strokeColor="#FF5252"
            app:strokeWidth="2dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="15dp"
            android:layout_marginBottom="15dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="15dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DATOS PERSONALES" android:textColor="#FF5252" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nombre" android:textColor="#888888" android:textSize="10sp" />
                <EditText android:id="@+id/etNombrePerfil" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:backgroundTint="#333333" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Edad" android:textColor="#888888" android:textSize="10sp" />
                        <EditText android:id="@+id/etEdadPerfil" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="number" android:textColor="#FFFFFF" android:backgroundTint="#333333" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:orientation="vertical" android:layout_marginStart="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Género" android:textColor="#888888" android:textSize="10sp" />
                        <Spinner android:id="@+id/spinnerSexo" android:layout_width="match_parent" android:layout_height="45dp" android:backgroundTint="#FF5252" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="15dp"
            android:layout_marginBottom="15dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="15dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Peso (kg)" android:textColor="#888888" android:textSize="10sp" />
                    <EditText android:id="@+id/etPesoPerfil" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:textColor="#FFFFFF" android:backgroundTint="#333333" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="10dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Altura (cm)" android:textColor="#888888" android:textSize="10sp" />
                    <EditText android:id="@+id/etAlturaPerfil" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="number" android:textColor="#FFFFFF" android:backgroundTint="#333333" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="15dp"
            android:layout_marginBottom="15dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="15dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="OBJETIVOS Y ACTIVIDAD" android:textColor="#FF5252" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Objetivo Actual" android:textColor="#888888" android:textSize="10sp" />
                <Spinner android:id="@+id/spinnerObjetivo" android:layout_width="match_parent" android:layout_height="45dp" android:backgroundTint="#FF5252" android:layout_marginBottom="10dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nivel de Actividad" android:textColor="#888888" android:textSize="10sp" />
                <Spinner android:id="@+id/spinnerActividad" android:layout_width="match_parent" android:layout_height="45dp" android:backgroundTint="#FF5252" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#222222"
            app:cardCornerRadius="15dp"
            android:layout_marginBottom="25dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="15dp" android:gravity="center">
                <TextView android:id="@+id/tvValorIMC" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="#FFFFFF" android:textSize="30sp" android:textStyle="bold" />
                <TextView android:id="@+id/tvEstadoIMC" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Introduce tus datos" android:textColor="#FF5252" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnGuardarPerfil"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="GUARDAR CAMBIOS"
            android:textColor="#000000"
            android:backgroundTint="#FFFFFF"
            app:cornerRadius="12dp" />

    </LinearLayout>
</ScrollView>